{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_FRONTEND_API": false,
        "ENABLE_QT": false
      }
    },
    {
      "name": "macos",
      "displayName": "macOS Universal",
      "description": "Build ArVisual for macOS 12.0+ as a universal plugin bundle",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_macos",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Xcode",
      "warnings": {
        "dev": true,
        "deprecated": true
      },
      "cacheVariables": {
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64"
      }
    },
    {
      "name": "macos-ci",
      "inherits": ["macos"],
      "displayName": "macOS Universal CI",
      "description": "CI build for macOS universal plugin package",
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": false
      }
    },
    {
      "name": "ubuntu-x86_64",
      "displayName": "Ubuntu x86_64",
      "description": "Build ArVisual for Linux x86_64 using system OBS development packages",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x86_64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "warnings": {
        "dev": true,
        "deprecated": true
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_LIBDIR": "lib/CMAKE_SYSTEM_PROCESSOR-linux-gnu"
      }
    },
    {
      "name": "ubuntu-ci-x86_64",
      "inherits": ["ubuntu-x86_64"],
      "displayName": "Ubuntu x86_64 CI",
      "description": "CI build for Linux x86_64 plugin package",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_COMPILE_WARNING_AS_ERROR": false
      }
    },
    {
      "name": "windows-vs2026-x64",
      "displayName": "Windows x64 - Visual Studio 2026",
      "description": "Build ArVisual for Windows x64 using Visual Studio 2026 / MSVC v14.50+",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_vs2026_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "windows-vs2022-x64",
      "displayName": "Windows x64 - Visual Studio 2022",
      "description": "Build ArVisual for Windows x64 using Visual Studio 2022 / MSVC v143",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_vs2022_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "windows-x64",
      "inherits": "windows-vs2022-x64",
      "displayName": "Windows x64 - Default CI",
      "description": "Default Windows preset kept on Visual Studio 2022 for GitHub Actions windows-2022 compatibility"
    },
    {
      "name": "windows-ci-x64",
      "inherits": "windows-vs2022-x64",
      "displayName": "Windows x64 CI build",
      "description": "CI build for Windows x64 on GitHub Actions windows-2022",
      "cacheVariables": {
        "CMAKE_COMPILE_WARNING_AS_ERROR": false
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos",
      "configurePreset": "macos",
      "displayName": "macOS Universal",
      "description": "macOS universal plugin build",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "macos-ci",
      "configurePreset": "macos-ci",
      "displayName": "macOS Universal CI",
      "description": "macOS CI build",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ubuntu-x86_64",
      "configurePreset": "ubuntu-x86_64",
      "displayName": "Ubuntu x86_64",
      "description": "Linux x86_64 plugin build",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ubuntu-ci-x86_64",
      "configurePreset": "ubuntu-ci-x86_64",
      "displayName": "Ubuntu x86_64 CI",
      "description": "Linux x86_64 CI build",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-vs2026-x64",
      "configurePreset": "windows-vs2026-x64",
      "displayName": "Windows x64 - Visual Studio 2026",
      "description": "Windows build for x64 using VS 2026",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-vs2022-x64",
      "configurePreset": "windows-vs2022-x64",
      "displayName": "Windows x64 - Visual Studio 2022",
      "description": "Windows build for x64 using VS 2022",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "displayName": "Windows x64 - Default CI",
      "description": "Default Windows x64 build preset",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-ci-x64",
      "configurePreset": "windows-ci-x64",
      "displayName": "Windows x64 CI",
      "description": "Windows CI build for x64",
      "configuration": "RelWithDebInfo"
    }
  ]
}
